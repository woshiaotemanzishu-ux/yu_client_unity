  m_text: "\u7528\u6237\u534F\u8BAE\u548C\u9690\u79C1\u4FDD\u62A4\u6307\u5F15\u8BF7\u4F60\u52A1\u5FC5\u5BA1\u614E\u9605\u8BFB,\u5145\u5206\u7406\u89E3\u201C\u7528\u6237\u534F\u8BAE\u201D\u548C\u201C\u9690\u79C1\u4FDD\u62A4\u6307\u5F15\u201D\u5404\u6761\u6B3E,\u5305\u62EC\u4F46\u4E0D\u9650\u4E8E:\u4E3A\u4E86\u5411\u4F60\u63D0\u4F9B\u5373\u65F6\u901A\u8BAF\u3001\u5185\u5BB9\u5206\u4EAB\u7B49\u670D\u52A1,\u6211\u4EEC\u9700\u8981\u6536\u96C6\u4F60\u7684\u8BBE\u5907\u4FE1\u606F\u3001\u64CD\u4F5C\u65E5\u5FD7\u7B49\u4E2A\u4EBA\u4FE1\u606F\u3002\u4F60\u53EF\u4EE5\u5728\u201C\u8BBE\u7F6E\u201D\u4E2D\u67E5\u770B\u3001\u53D8\u66F4\u3001\u5220\u9664\u4E2A\u4EBA\u4FE1\u606F\u5E76\u7BA1\u7406\u4F60\u7684\u6388\u6743\u3002\u4F60\u53EF\u9605\u8BFB\u300A\u7528\u6237\u534F\u8BAE\u300B\uFF0C\u300A\u9690\u79C1\u4FDD\u62A4\u6307\u5F15\u300B\u4E86\u89E3\u8BE6\u7EC6\u4FE1\u606F\u3002\u5982\u4F60\u540C\u610F,\u8BF7\u70B9\u51FB\u540C\u610F\u201C\u5F00\u59CB\u63A5\u53D7\u6211\u4EEC\u7684\u670D\u52A1\u201D\u3002"
